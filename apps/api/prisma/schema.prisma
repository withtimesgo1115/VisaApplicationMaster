generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model VisaRuleVersion {
  id                String   @id @default(uuid())
  destinationCode   String
  visaType          String
  version           String
  sourceUrl         String
  requiredDocuments Json
  createdAt         DateTime @default(now())

  @@index([destinationCode, visaType])
}
